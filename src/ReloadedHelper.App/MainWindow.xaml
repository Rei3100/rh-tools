<Window x:Class="ReloadedHelper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:ReloadedHelper.App"
        Title="Reloaded Helper" Height="700" Width="1100">
    <Window.Resources>
        <app:PathToImageConverter x:Key="Img"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="ゲーム" FontWeight="Bold" Margin="0,0,0,4"/>
            <ListBox ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}"
                     DisplayMemberPath="DisplayName"/>
        </DockPanel>

        <DockPanel Grid.Column="1" Margin="8,0">
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,4"/>
            <ListView ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="40" DisplayMemberBinding="{Binding Order}"/>
                        <GridViewColumn Header="ON" Width="44" DisplayMemberBinding="{Binding Enabled}"/>
                        <GridViewColumn Header="MOD" Width="420" DisplayMemberBinding="{Binding DisplayName}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <ScrollViewer Grid.Column="2">
            <StackPanel DataContext="{Binding SelectedEntry}">
                <Image Source="{Binding Info.IconPath, Converter={StaticResource Img}}"
                       MaxHeight="180" Stretch="Uniform" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding ModId}" Foreground="Gray" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Info.ModAuthor, StringFormat=作者: {0}}"/>
                <TextBlock Text="{Binding Info.ModVersion, StringFormat=バージョン: {0}}"/>
                <TextBlock Text="{Binding Info.ProjectUrl, StringFormat=URL: {0}}" TextWrapping="Wrap"/>
                <TextBlock Text="説明" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Text="{Binding Info.ModDescription}" TextWrapping="Wrap"/>
                <TextBlock Text="依存関係" FontWeight="Bold" Margin="0,8,0,2"/>
                <ItemsControl ItemsSource="{Binding Info.Dependencies}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
