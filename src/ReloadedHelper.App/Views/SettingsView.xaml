<UserControl x:Class="ReloadedHelper.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgMainBrush}">
    <!-- DataContext = SettingsViewModel -->
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="32,24" MaxWidth="520" HorizontalAlignment="Left">

            <!-- タイトル -->
            <TextBlock Text="設定"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,28"/>

            <!-- ── UI 拡大率 ── -->
            <TextBlock Text="UI 拡大率"
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextLabelBrush}"
                       Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0"
                        Minimum="80" Maximum="200"
                        Value="{Binding UiZoomPercent}"
                        SmallChange="1" LargeChange="10"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding UiZoomPercent, UpdateSourceTrigger=LostFocus}"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         Height="32"/>
                <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLabelBrush}" Margin="4,0,0,0"/>
            </Grid>

            <Button Content="100% にリセット" HorizontalAlignment="Left"
                    Padding="16,6" Margin="0,0,0,24"
                    Background="{DynamicResource BgInputBrush}"
                    Foreground="{DynamicResource TextBodyBrush}"
                    BorderBrush="{DynamicResource BorderInputBrush}" BorderThickness="1"
                    Cursor="Hand"
                    Click="ResetZoom_Click"/>

            <!-- 区切り -->
            <Border Height="1" Background="{DynamicResource BgSeparatorBrush}" Margin="0,0,0,24"/>

            <!-- ── Reloaded-II フォルダ ── -->
            <TextBlock Text="Reloaded-II フォルダ"
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextLabelBrush}"
                       Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ReloadedInstallPath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,8,0" Height="32"/>
                <Button Grid.Column="1" Content="変更..." Padding="12,0" Height="32"
                        Background="{DynamicResource BgInputBrush}"
                        Foreground="{DynamicResource TextBodyBrush}"
                        BorderBrush="{DynamicResource BorderInputBrush}" BorderThickness="1"
                        Cursor="Hand"
                        Click="ChangeFolder_Click"/>
            </Grid>

            <!-- 区切り -->
            <Border Height="1" Background="{DynamicResource BgSeparatorBrush}" Margin="0,0,0,24"/>

            <!-- ── 起動時の動作 ── -->
            <TextBlock Text="起動時の動作"
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextLabelBrush}"
                       Margin="0,0,0,12"/>

            <CheckBox Content="最小化したらタスクトレイに格納する"
                      IsChecked="{Binding MinimizeToTray}"
                      Foreground="{DynamicResource TextBodyBrush}"
                      Margin="0,0,0,10"/>
            <CheckBox Content="最後に開いていたゲームを覚える"
                      IsChecked="{Binding RememberLastGame}"
                      Foreground="{DynamicResource TextBodyBrush}"
                      Margin="0,0,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
